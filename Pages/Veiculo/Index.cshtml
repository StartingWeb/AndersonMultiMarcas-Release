@page
@model Concessionaria.Pages.Veiculo.IndexModel
@{
    ViewData["Title"] = "Veículos";
    ViewData["TopbarTitle"] = "Veículos";
    ViewData["TopbarSubtitle"] = "Gerencie os veículos cadastrados";
    Layout = "_LayoutAdmin";

    var veiculos = Model.Veiculos ?? new List<Domain.Veiculo>();
    var totalVeiculos = veiculos.Count();
}

<style>
    :root {
        --brand-primary: #9f0a10;
        --brand-dark: #222222;
        --brand-border: #ececec;
        --brand-muted: #6c757d;
        --brand-soft: rgba(159, 10, 16, 0.08);
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .page-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0;
    }

    .page-subtitle {
        font-size: .88rem;
        color: var(--brand-muted);
        margin: .15rem 0 0 0;
    }

    .search-card {
        background: #fff;
        border: 1px solid var(--brand-border);
        border-radius: .9rem;
        box-shadow: 0 6px 18px rgba(0,0,0,.04);
        margin-bottom: 1rem;
    }

    .search-card .card-body {
        padding: .9rem;
    }

    .filter-label {
        font-size: .78rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin-bottom: .35rem;
    }

    .form-control,
    .form-select {
        border-radius: .75rem;
        border: 1px solid #e6e6e6;
        min-height: 42px;
        box-shadow: none !important;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: rgba(159, 10, 16, .35);
        box-shadow: 0 0 0 .2rem rgba(159, 10, 16, .08) !important;
    }

    .input-icon-wrap {
        position: relative;
    }

    .input-icon-wrap i {
        position: absolute;
        left: .9rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--brand-muted);
        font-size: .95rem;
    }

    .input-icon-wrap .form-control {
        padding-left: 2.4rem;
    }

    .btn-brand {
        background: var(--brand-primary);
        border-color: var(--brand-primary);
        color: #fff;
        border-radius: .75rem;
        font-weight: 600;
        min-height: 42px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .btn-brand:hover {
        background: #86080d;
        border-color: #86080d;
        color: #fff;
    }

    .btn-soft-dark {
        background: #fff;
        border: 1px solid var(--brand-border);
        color: var(--brand-dark);
        border-radius: .75rem;
        font-weight: 600;
        min-height: 42px;
    }

    .btn-soft-dark:hover {
        background: #f8f8f8;
        color: var(--brand-dark);
    }

    .btn-danger-soft {
        width: 42px;
        height: 42px;
        border-radius: .75rem;
        font-weight: 700;
        border: 1px solid #f4c7cb;
        background: #fff4f4;
        color: #b42318;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-danger-soft:hover {
        background: #b42318;
        border-color: #b42318;
        color: #fff;
    }

    .search-actions-row {
        display: flex;
        justify-content: flex-end;
    }

    .search-actions {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        width: 100%;
    }

    .search-actions .btn {
        min-width: 130px;
    }

    .results-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: .9rem;
    }

    .results-title {
        font-size: .98rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0;
    }

    .results-counter {
        font-size: .88rem;
        color: var(--brand-muted);
    }

    .list-card {
        background: #fff;
        border: 1px solid var(--brand-border);
        border-radius: 1rem;
        box-shadow: 0 8px 24px rgba(0,0,0,.05);
        overflow: hidden;
    }

    .vehicle-table {
        margin: 0;
        vertical-align: middle;
    }

    .vehicle-table thead th {
        background: #f8f8f8;
        color: var(--brand-dark);
        font-size: .76rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .04em;
        border-bottom: 1px solid var(--brand-border);
        padding: 1rem .9rem;
        white-space: nowrap;
    }

    .vehicle-table tbody td {
        padding: 1rem .9rem;
        border-color: #f1f1f1;
        color: var(--brand-dark);
    }

    .vehicle-title-cell {
        display: flex;
        flex-direction: column;
        gap: .2rem;
        min-width: 220px;
    }

    .vehicle-title-main {
        font-size: .95rem;
        font-weight: 700;
        line-height: 1.3;
    }

    .vehicle-title-sub {
        font-size: .8rem;
        color: var(--brand-muted);
        line-height: 1.25;
    }

    .vehicle-muted {
        color: var(--brand-muted);
        font-size: .88rem;
    }

    .vehicle-price {
        font-size: .95rem;
        font-weight: 800;
        color: var(--brand-primary);
        white-space: nowrap;
    }

    .table-action {
        width: 42px;
        height: 42px;
        min-width: 42px;
        padding: 0;
    }

    .table-row-actions {
        display: flex;
        justify-content: flex-end;
        gap: .6rem;
        flex-wrap: wrap;
    }

    .empty-state {
        border: 1px dashed #dadada;
        border-radius: 1rem;
        padding: 2.2rem 1.2rem;
        text-align: center;
        background: #fff;
    }

    .empty-state-icon {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        margin: 0 auto .9rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--brand-soft);
        color: var(--brand-primary);
        font-size: 1.6rem;
    }

    @@media (max-width: 768px) {
        .page-header,
        .results-topbar,
        .search-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .search-actions .btn {
            min-width: 100%;
        }

        .table-row-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .table-row-actions .btn,
        .table-row-actions form,
        .table-row-actions .btn-danger-soft {
            width: auto;
        }
    }
</style>

<div class="container-fluid vehicle-page">

    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-car-front-fill me-2"></i>
                Veículos
            </h1>
            <p class="page-subtitle">Lista e gerenciamento dos veículos cadastrados</p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a href="/Veiculo/ImportaJSON" class="btn btn-soft-dark px-3">
                <i class="bi bi-filetype-json me-2"></i>
                Importar legado
            </a>

            <a href="/Veiculo/Upsert" class="btn btn-brand px-3">
                <i class="bi bi-plus-circle me-2"></i>
                Novo veículo
            </a>
        </div>
    </div>

    <div class="search-card card">
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-12 col-md-4 col-xl-2">
                        <label class="filter-label">Código</label>
                        <input type="number"
                               name="Codigo"
                               value="@Model.Codigo"
                               class="form-control"
                               min="1"
                               placeholder="Ex.: 123" />
                    </div>

                    <div class="col-12 col-md-8 col-xl-4">
                        <label class="filter-label">Pesquisar veículo</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-search"></i>
                            <input type="text"
                                   name="Filtro"
                                   value="@Model.Filtro"
                                   class="form-control"
                                   placeholder="Título, modelo, versão, placa..." />
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label">Ordenação</label>
                        <select name="Ordem" class="form-select">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Ordem))">Mais recentes</option>
                            <option value="antigos" selected="@(Model.Ordem == "antigos")">Mais antigos</option>
                            <option value="titulo" selected="@(Model.Ordem == "titulo")">Título (A-Z)</option>
                            <option value="titulo_desc" selected="@(Model.Ordem == "titulo_desc")">Título (Z-A)</option>
                            <option value="preco_asc" selected="@(Model.Ordem == "preco_asc")">Menor preço</option>
                            <option value="preco_desc" selected="@(Model.Ordem == "preco_desc")">Maior preço</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-3 col-xl-2">
                        <label class="filter-label">Status</label>
                        <select name="SomenteAtivos" class="form-select">
                            <option value="">Todos</option>
                            <option value="true" selected="@(Model.SomenteAtivos == true)">Ativos</option>
                            <option value="false" selected="@(Model.SomenteAtivos == false)">Inativos</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-3 col-xl-2">
                        <label class="filter-label">Venda</label>
                        <select name="SomenteVendidos" class="form-select">
                            <option value="false" selected="@(Model.SomenteVendidos == false)">Disponíveis</option>
                            <option value="true" selected="@(Model.SomenteVendidos == true)">Vendidos</option>
                            <option value="">Todos</option>
                        </select>
                    </div>

                    <div class="col-12 col-xl-1 d-none d-xl-block"></div>

                    <div class="col-12">
                        <div class="search-actions-row">
                            <div class="search-actions">
                                <button type="submit" class="btn btn-brand">
                                    <i class="bi bi-search me-2"></i>
                                    Buscar
                                </button>

                                <a asp-page="./Index" class="btn btn-soft-dark">
                                    <i class="bi bi-arrow-counterclockwise me-2"></i>
                                    Limpar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="results-topbar">
        <h5 class="results-title">Veículos cadastrados</h5>
        <div class="results-counter">
            <strong>@totalVeiculos</strong> registro(s)
        </div>
    </div>

    @if (veiculos.Any())
    {
        <div class="list-card">
            <div class="table-responsive">
                <table class="table vehicle-table admin-responsive-table">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Placa</th>
                            <th>Mês/Ano</th>
                            <th>Condição</th>
                            <th>Preço</th>
                            <th class="text-end">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var veiculo in veiculos)
                        {
                            var titulo = (!string.IsNullOrWhiteSpace(veiculo.Marca?.Nome) || !string.IsNullOrWhiteSpace(veiculo.Modelo))
                                ? string.Join(" ", new[] { veiculo.Marca?.Nome, veiculo.Modelo }.Where(x => !string.IsNullOrWhiteSpace(x)))
                                : (string.IsNullOrWhiteSpace(veiculo.Titulo) ? $"{veiculo.Marca?.Nome} {veiculo.Versao}".Trim() : veiculo.Titulo);

                            var subtitulo = string.Join(" • ", new[]
                            {
                                veiculo.Marca?.Nome,
                                veiculo.Modelo,
                                veiculo.Versao
                            }.Where(x => !string.IsNullOrWhiteSpace(x)));

                            var mesAno = veiculo.DataCadastro != default
                                ? veiculo.DataCadastro.ToString("MM/yyyy")
                                : "-";

                            var precoPrincipal = veiculo.PrecoVenda;

                            var condicaoVeiculo = veiculo.Seminovo ? "Seminovo" : "0km";

                            <tr>
                                <td data-label="Título">
                                    <div class="vehicle-title-cell">
                                        <span class="vehicle-title-main">@titulo</span>
                                        @if (!string.IsNullOrWhiteSpace(subtitulo))
                                        {
                                            <span class="vehicle-title-sub">@subtitulo</span>
                                        }
                                    </div>
                                </td>
                                <td data-label="Placa">
                                    <span class="vehicle-muted">
                                        @(string.IsNullOrWhiteSpace(veiculo.Placa) ? "-" : veiculo.Placa)
                                    </span>
                                </td>
                                <td data-label="Mês/Ano">
                                    <span class="vehicle-muted">@mesAno</span>
                                </td>
                                <td data-label="Condição">
                                    <span class="vehicle-muted">@condicaoVeiculo</span>
                                </td>
                                <td data-label="Preço">
                                    <span class="vehicle-price">
                                        @(precoPrincipal.HasValue ? precoPrincipal.Value.ToBrazilianCurrency() : "Não informado")
                                    </span>
                                </td>
                                <td class="text-end" data-label="Ação">
                                    <div class="table-row-actions">
                                        <a asp-page="./Upsert" asp-route-id="@veiculo.Id" class="btn btn-brand table-action">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <form method="post" asp-page-handler="Delete" class="m-0">
                                            <input type="hidden" name="id" value="@veiculo.Id" />
                                            <input type="hidden" name="Filtro" value="@Model.Filtro" />
                                            <input type="hidden" name="Codigo" value="@Model.Codigo" />
                                            <input type="hidden" name="Ordem" value="@Model.Ordem" />
                                            <input type="hidden" name="SomenteAtivos" value="@Model.SomenteAtivos" />
                                            <input type="hidden" name="SomenteVendidos" value="@Model.SomenteVendidos" />
                                            <button type="button" class="btn-danger-soft table-action" data-confirm-delete data-confirm-message="Deseja excluir este veículo?">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-car-front"></i>
            </div>

            <h5 class="fw-bold mb-2">Nenhum veículo encontrado</h5>
            <p class="text-muted mb-4">
                Não encontramos veículos com os filtros informados.
            </p>

            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <a asp-page="./Index" class="btn btn-soft-dark">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>
                    Limpar filtros
                </a>

                <a asp-page="/Veiculo/Upsert" class="btn btn-brand">
                    <i class="bi bi-plus-circle me-2"></i>
                    Cadastrar veículo
                </a>
            </div>
        </div>
    }
</div>

