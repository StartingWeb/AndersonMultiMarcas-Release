@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Aceita números no formato pt-BR no jQuery Validate
        if (window.jQuery && $.validator) {
            $.validator.methods.number = function (value, element) {
                return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:\.\d{3})+)(?:,\d{1,2})?$/.test(value);
            };
        }
    </script>

    <script>
        (function () {
            const form = document.getElementById('formVeiculo');
            const mediaInput = document.getElementById('NovasMidias');
            const mediaDropzone = document.getElementById('mediaDropzone');
            const mediaList = document.getElementById('mediaList');
            const btnSelecionarMidias = document.getElementById('btnSelecionarMidias');
            const btnLimparNovasMidias = document.getElementById('btnLimparNovasMidias');
            const midiasOrdenadasJson = document.getElementById('MidiasOrdenadasJson');
            const capaItemKey = document.getElementById('CapaItemKey');

            const selectMarca = document.getElementById('Veiculo_MarcaId');
            const inputNovaMarca = document.getElementById('inputNovaMarca');
            const btnSalvarNovaMarca = document.getElementById('btnSalvarNovaMarca');
            const hiddenNovaMarcaNome = document.getElementById('NovaMarcaNome');
            const modalNovaMarcaEl = document.getElementById('modalNovaMarca');
            const modalNovaMarca = modalNovaMarcaEl ? bootstrap.Modal.getOrCreateInstance(modalNovaMarcaEl) : null;

            let newFiles = [];
            let dragItem = null;

            function bindSwitchStatus(inputId, statusId, onText, offText, activeWhenChecked = true) {
                const input = document.getElementById(inputId);
                const status = document.getElementById(statusId);
                if (!input || !status) return;

                function update() {
                    const active = activeWhenChecked ? input.checked : !input.checked;
                    status.textContent = input.checked ? onText : offText;

                    if (active) status.classList.add('active');
                    else status.classList.remove('active');
                }

                input.addEventListener('change', update);
                update();
            }

            bindSwitchStatus('Veiculo_Ativo', 'statusVeiculoAtivo', 'Ativo', 'Inativo');
            bindSwitchStatus('Veiculo_Vendido', 'statusVeiculoVendido', 'Sim', 'Não');
            bindSwitchStatus('Veiculo_Destaque', 'statusVeiculoDestaque', 'Sim', 'Não');
            bindSwitchStatus('Veiculo_Seminovo', 'statusVeiculoSeminovo', 'Sim', 'Não');
            bindSwitchStatus('Veiculo_MotoEletrica', 'statusVeiculoMotoEletrica', 'Sim', 'Não');
            bindSwitchStatus('Veiculo_AceitaTroca', 'statusVeiculoAceitaTroca', 'Sim', 'Não');
            bindSwitchStatus('Veiculo_Financiavel', 'statusVeiculoFinanciavel', 'Sim', 'Não');

            function formatBytes(bytes) {
                if (!bytes || bytes <= 0) return '0 KB';
                const kb = bytes / 1024;
                if (kb < 1024) return kb.toFixed(0) + ' KB';
                const mb = kb / 1024;
                return mb.toFixed(2) + ' MB';
            }

            function digitsOnly(value) {
                return (value || '').replace(/\D/g, '');
            }

            function lettersAndNumbersOnly(value) {
                return (value || '').replace(/[^a-zA-Z0-9]/g, '');
            }

            function formatMoney(value) {
                const digits = digitsOnly(value);
                if (!digits) return '';

                const cents = parseInt(digits, 10);
                if (isNaN(cents)) return '';

                const number = (cents / 100).toFixed(2);
                const parts = number.split('.');

                parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, '.');

                return parts[0] + ',' + parts[1];
            }

            function formatIntegerWithThousands(value) {
                const digits = digitsOnly(value);
                if (!digits) return '';
                return parseInt(digits, 10).toLocaleString('pt-BR');
            }

            function formatPlaca(value) {
                return lettersAndNumbersOnly(value).toUpperCase().substring(0, 7);
            }

            function applyInputMasks() {
                document.querySelectorAll('.js-mask-money').forEach(input => {
                    input.addEventListener('input', function () {
                        this.value = formatMoney(this.value);
                    });

                    input.addEventListener('blur', function () {
                        this.value = formatMoney(this.value);
                    });

                    if (input.value) {
                        input.value = formatMoney(input.value);
                    }
                });

                document.querySelectorAll('.js-mask-km').forEach(input => {
                    input.addEventListener('input', function () {
                        this.value = formatIntegerWithThousands(this.value);
                    });

                    input.addEventListener('blur', function () {
                        this.value = formatIntegerWithThousands(this.value);
                    });

                    if (input.value) {
                        input.value = formatIntegerWithThousands(input.value);
                    }
                });

                document.querySelectorAll('.js-mask-placa').forEach(input => {
                    input.addEventListener('input', function () {
                        this.value = formatPlaca(this.value);
                    });

                    input.addEventListener('blur', function () {
                        this.value = formatPlaca(this.value);
                    });

                    if (input.value) {
                        input.value = formatPlaca(input.value);
                    }
                });

            }

            function normalizeMaskedInputsBeforeSubmit() {
                document.querySelectorAll('.js-mask-km').forEach(input => {
                    input.value = digitsOnly(input.value);
                });

                document.querySelectorAll('.js-mask-money').forEach(input => {
                    let value = (input.value || '').trim();

                    if (!value) {
                        input.value = '';
                        return;
                    }

                    // Envia em formato pt-BR para o model binder da aplicação
                    // Ex.: 58.000,00 -> 58000,00
                    input.value = value.replace(/\./g, '');
                });

                document.querySelectorAll('.js-mask-placa').forEach(input => {
                    input.value = formatPlaca(input.value);
                });
            }

            function bindSelectAllButtons() {
                document.querySelectorAll('.btn-selecionar-todos').forEach(button => {
                    button.addEventListener('click', function () {
                        const targetSelector = this.getAttribute('data-target');
                        const group = document.querySelector(targetSelector);

                        if (!group) return;

                        const checkboxes = group.querySelectorAll('input[type="checkbox"]');
                        checkboxes.forEach(cb => {
                            cb.checked = true;
                            cb.dispatchEvent(new Event('change', { bubbles: true }));
                        });
                    });
                });
            }

            function bindBaseCarroButton() {
                const button = document.getElementById('btnBaseCarro');
                if (!button) return;

                const baseCarroIds = [
                    'Caracteristica_ArCondicionado',
                    'Caracteristica_VidroEletrico',
                    'Caracteristica_TravaEletrica',
                    'Caracteristica_ComputadorBordo',
                    'Caracteristica_AirbagMotorista',
                    'Caracteristica_AirbagPassageiro',
                    'Caracteristica_FreiosAbs',
                    'Caracteristica_Alarme',
                    'Caracteristica_Som',
                    'Caracteristica_Bluetooth',
                    'Caracteristica_Usb',
                    'Caracteristica_Radio',
                    'Caracteristica_RodaLigaLeve',
                    'Caracteristica_CambioManual',
                    'Caracteristica_TracaoDianteira'
                ];

                button.addEventListener('click', function () {
                    baseCarroIds.forEach(id => {
                        const checkbox = document.getElementById(id);
                        if (!checkbox) return;

                        checkbox.checked = true;
                        checkbox.dispatchEvent(new Event('change', { bubbles: true }));
                    });
                });
            }

            function bindNovaMarca() {
                if (!btnSalvarNovaMarca || !selectMarca) return;

                btnSalvarNovaMarca.addEventListener('click', function () {
                    const nomeMarca = (inputNovaMarca?.value || '').trim();

                    if (!nomeMarca) {
                        if (inputNovaMarca) inputNovaMarca.focus();
                        return;
                    }

                    const optionExistente = Array.from(selectMarca.options)
                        .find(opt => (opt.text || '').trim().toLowerCase() === nomeMarca.toLowerCase());

                    if (optionExistente) {
                        selectMarca.value = optionExistente.value;
                        hiddenNovaMarcaNome.value = '';
                        modalNovaMarca?.hide();
                        if (inputNovaMarca) inputNovaMarca.value = '';
                        return;
                    }

                    const tempValue = 'nova:' + nomeMarca;
                    const option = new Option(nomeMarca, tempValue, true, true);
                    selectMarca.add(option);
                    selectMarca.value = tempValue;
                    hiddenNovaMarcaNome.value = nomeMarca;

                    modalNovaMarca?.hide();
                    if (inputNovaMarca) inputNovaMarca.value = '';
                });

                modalNovaMarcaEl?.addEventListener('hidden.bs.modal', function () {
                    if (inputNovaMarca) inputNovaMarca.value = '';
                });
            }

            function createNewMediaCard(file, index) {
                const key = `new-${index}`;
                const objectUrl = URL.createObjectURL(file);

                const wrapper = document.createElement('div');
                wrapper.className = 'media-item';
                wrapper.setAttribute('draggable', 'true');
                wrapper.dataset.kind = 'new';
                wrapper.dataset.newIndex = String(index);
                wrapper.dataset.key = key;

                wrapper.innerHTML = `
                    <div class="media-badge">NOVA</div>
                    <div class="media-thumb">
                        <img src="${objectUrl}" alt="${file.name}" />
                    </div>
                    <div class="media-body">
                        <p class="media-name">${file.name}</p>
                        <div class="media-meta">
                            ${formatBytes(file.size)}
                        </div>
                        <div class="media-actions">
                            <label class="form-check">
                                <input class="form-check-input js-capa-radio"
                                       type="radio"
                                       name="capaSelector"
                                       value="${key}" />
                                <span class="form-check-label">Definir como capa</span>
                            </label>

                            <button type="button" class="btn btn-outline-danger btn-sm media-remove-btn js-remove-new-file">
                                <i class="bi bi-trash me-1"></i>
                                Remover
                            </button>

                            <div class="media-order-label">Arraste para ordenar</div>
                        </div>
                    </div>
                `;

                const removeButton = wrapper.querySelector('.js-remove-new-file');
                removeButton.addEventListener('click', function () {
                    const currentIndex = parseInt(wrapper.dataset.newIndex, 10);
                    if (!isNaN(currentIndex)) {
                        newFiles.splice(currentIndex, 1);
                        renderNewFiles();
                    }
                });

                return wrapper;
            }

            function renderNewFiles() {
                const existingCards = Array.from(mediaList.querySelectorAll('.media-item[data-kind="existing"]'));

                mediaList.innerHTML = '';
                existingCards.forEach(card => mediaList.appendChild(card));

                newFiles.forEach((file, index) => {
                    const card = createNewMediaCard(file, index);
                    mediaList.appendChild(card);
                });

                refreshDragAndDrop();
                restoreSelectedCoverIfNeeded();
                syncFileInputFromArray();
            }

            function restoreSelectedCoverIfNeeded() {
                const current = capaItemKey.value;
                if (!current) return;

                const radio = mediaList.querySelector(`.js-capa-radio[value="${current}"]`);
                if (radio) {
                    radio.checked = true;
                } else {
                    capaItemKey.value = '';
                }
            }

            function syncFileInputFromArray() {
                if (!mediaInput) return;

                const dt = new DataTransfer();
                newFiles.forEach(file => dt.items.add(file));
                mediaInput.files = dt.files;
            }

            function appendFiles(files) {
                const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];

                Array.from(files).forEach(file => {
                    const type = (file.type || '').toLowerCase();
                    if (!validTypes.includes(type)) return;
                    newFiles.push(file);
                });

                renderNewFiles();
            }

            function collectOrder() {
                const items = [];
                const cards = Array.from(mediaList.querySelectorAll('.media-item'));

                cards.forEach((card, index) => {
                    items.push({
                        key: card.dataset.key,
                        kind: card.dataset.kind,
                        id: card.dataset.id ? parseInt(card.dataset.id, 10) : null,
                        newIndex: card.dataset.newIndex ? parseInt(card.dataset.newIndex, 10) : null,
                        ordem: index
                    });
                });

                midiasOrdenadasJson.value = JSON.stringify(items);
            }

            function updateCapaHidden() {
                const selected = document.querySelector('.js-capa-radio:checked');
                capaItemKey.value = selected ? selected.value : '';
            }

            function refreshNewIndexesFromDom() {
                const newCards = Array.from(mediaList.querySelectorAll('.media-item[data-kind="new"]'));
                const reorderedFiles = [];

                newCards.forEach((card, idx) => {
                    const oldIndex = parseInt(card.dataset.newIndex, 10);

                    if (!isNaN(oldIndex) && newFiles[oldIndex]) {
                        reorderedFiles.push(newFiles[oldIndex]);
                    }

                    card.dataset.newIndex = String(idx);
                    card.dataset.key = `new-${idx}`;

                    const radio = card.querySelector('.js-capa-radio');
                    if (radio) radio.value = `new-${idx}`;
                });

                newFiles = reorderedFiles;
                syncFileInputFromArray();
                updateCapaHidden();
                collectOrder();
            }

            function refreshExistingBadges() {
                const cards = Array.from(mediaList.querySelectorAll('.media-item'));

                cards.forEach(card => {
                    const badge = card.querySelector('.media-badge');
                    const radio = card.querySelector('.js-capa-radio');
                    if (!badge || !radio) return;

                    if (radio.checked) {
                        badge.textContent = 'CAPA';
                    } else if (card.dataset.kind === 'new') {
                        badge.textContent = 'NOVA';
                    } else {
                        badge.textContent = 'MÍDIA';
                    }
                });
            }

            function onDragStart() {
                dragItem = this;
                this.classList.add('dragging');
            }

            function onDragEnd() {
                this.classList.remove('dragging');
                dragItem = null;
                refreshNewIndexesFromDom();
                refreshExistingBadges();
            }

            function onDragOver(e) {
                e.preventDefault();
            }

            function onDrop(e) {
                e.preventDefault();
                if (!dragItem || dragItem === this) return;

                const list = mediaList;
                const cards = Array.from(list.children);
                const draggedIndex = cards.indexOf(dragItem);
                const targetIndex = cards.indexOf(this);

                if (draggedIndex < targetIndex) {
                    list.insertBefore(dragItem, this.nextSibling);
                } else {
                    list.insertBefore(dragItem, this);
                }

                refreshNewIndexesFromDom();
                refreshExistingBadges();
            }

            function bindCapaRadios() {
                const radios = document.querySelectorAll('.js-capa-radio');
                radios.forEach(radio => {
                    radio.removeEventListener('change', onCapaChange);
                    radio.addEventListener('change', onCapaChange);
                });
            }

            function onCapaChange() {
                updateCapaHidden();
                refreshExistingBadges();
            }

            function refreshDragAndDrop() {
                const cards = mediaList.querySelectorAll('.media-item');

                cards.forEach(card => {
                    card.removeEventListener('dragstart', onDragStart);
                    card.removeEventListener('dragend', onDragEnd);
                    card.removeEventListener('dragover', onDragOver);
                    card.removeEventListener('drop', onDrop);

                    card.addEventListener('dragstart', onDragStart);
                    card.addEventListener('dragend', onDragEnd);
                    card.addEventListener('dragover', onDragOver);
                    card.addEventListener('drop', onDrop);
                });

                bindCapaRadios();
            }

            if (btnSelecionarMidias) {
                btnSelecionarMidias.addEventListener('click', function () {
                    if (mediaInput) mediaInput.click();
                });
            }

            if (mediaInput) {
                mediaInput.addEventListener('change', function () {
                    if (mediaInput.files && mediaInput.files.length > 0) {
                        appendFiles(mediaInput.files);
                    }
                    mediaInput.value = '';
                });
            }

            if (btnLimparNovasMidias) {
                btnLimparNovasMidias.addEventListener('click', function () {
                    newFiles = [];
                    renderNewFiles();
                });
            }

            if (mediaDropzone) {
                ['dragenter', 'dragover'].forEach(evt => {
                    mediaDropzone.addEventListener(evt, function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        mediaDropzone.classList.add('dragover');
                    });
                });

                ['dragleave', 'drop'].forEach(evt => {
                    mediaDropzone.addEventListener(evt, function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        mediaDropzone.classList.remove('dragover');
                    });
                });

                mediaDropzone.addEventListener('drop', function (e) {
                    const files = e.dataTransfer.files;
                    if (files && files.length > 0) {
                        appendFiles(files);
                    }
                });
            }

            if (form) {
                form.addEventListener('submit', function () {
                    refreshNewIndexesFromDom();
                    updateCapaHidden();
                    collectOrder();
                    normalizeMaskedInputsBeforeSubmit();
                });
            }

            applyInputMasks();
            bindSelectAllButtons();
            bindBaseCarroButton();
            bindNovaMarca();
            refreshDragAndDrop();
            updateCapaHidden();
            collectOrder();
            refreshExistingBadges();
        })();
</script>
}
