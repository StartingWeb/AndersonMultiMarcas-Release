@page "{id:int?}"
@model Concessionaria.Pages.Veiculo.UpsertModel
@{
    var isEdit = Model.Veiculo.Id > 0;

    ViewData["Title"] = isEdit ? "Editar Veículo" : "Novo Veículo";
    ViewData["TopbarTitle"] = isEdit ? "Editar Veículo" : "Novo Veículo";
    ViewData["TopbarSubtitle"] = isEdit ? "Atualize os dados do veículo" : "Cadastre um novo veículo";
    Layout = "_LayoutAdmin";
}

<style>
    :root {
        --brand-primary: #9f0a10;
        --brand-primary-dark: #86080d;
        --brand-dark: #222222;
        --brand-border: #ececec;
        --brand-muted: #6c757d;
        --brand-soft: rgba(159, 10, 16, 0.08);
        --brand-success: #198754;
        --brand-danger: #dc3545;
        --brand-warning: #ffc107;
        --brand-card-shadow: 0 8px 24px rgba(0,0,0,.05);
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .page-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0;
    }

    .page-subtitle {
        font-size: .92rem;
        color: var(--brand-muted);
        margin: .2rem 0 0 0;
    }

    .form-card {
        background: #fff;
        border: 1px solid var(--brand-border);
        border-radius: 1rem;
        box-shadow: var(--brand-card-shadow);
        overflow: hidden;
    }

    .form-card-body {
        padding: 1.25rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin-bottom: .2rem;
    }

    .section-subtitle {
        font-size: .85rem;
        color: var(--brand-muted);
        margin-bottom: 1rem;
    }

    .form-label {
        font-size: .84rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin-bottom: .35rem;
    }

    .form-help {
        display: block;
        font-size: .78rem;
        color: var(--brand-muted);
        margin-top: .4rem;
        line-height: 1.35;
    }

    .form-control,
    .form-select,
    textarea.form-control {
        border-radius: .85rem;
        border: 1px solid #e6e6e6;
        min-height: 46px;
        box-shadow: none !important;
    }

        .form-control:focus,
        .form-select:focus,
        textarea.form-control:focus {
            border-color: rgba(159, 10, 16, .35);
            box-shadow: 0 0 0 .2rem rgba(159, 10, 16, .08) !important;
        }

    textarea.form-control {
        min-height: 120px;
    }

    .text-danger {
        font-size: .8rem;
    }

    .btn-brand {
        background: var(--brand-primary);
        border-color: var(--brand-primary);
        color: #fff;
        border-radius: .85rem;
        font-weight: 600;
        min-height: 46px;
        padding: 0 1.25rem;
    }

        .btn-brand:hover {
            background: var(--brand-primary-dark);
            border-color: var(--brand-primary-dark);
            color: #fff;
        }

    .btn-soft-dark {
        background: #fff;
        border: 1px solid var(--brand-border);
        color: var(--brand-dark);
        border-radius: .85rem;
        font-weight: 600;
        min-height: 46px;
        padding: 0 1.25rem;
        display: inline-flex;
        justify-content: center;
        align-items: center;
    }

        .btn-soft-dark:hover {
            background: #f8f8f8;
            color: var(--brand-dark);
        }

    .btn-soft-primary {
        background: rgba(159, 10, 16, .06);
        border: 1px solid rgba(159, 10, 16, .14);
        color: var(--brand-primary);
        border-radius: .85rem;
        font-weight: 600;
        min-height: 46px;
        padding: 0 1rem;
        display: inline-flex;
        justify-content: center;
        align-items: center;
    }

        .btn-soft-primary:hover {
            background: rgba(159, 10, 16, .1);
            color: var(--brand-primary-dark);
            border-color: rgba(159, 10, 16, .22);
        }

    .switch-field {
        display: flex;
        flex-direction: column;
        gap: .45rem;
    }

    .switch-wrapper {
        display: inline-flex;
        align-items: center;
        gap: .75rem;
        user-select: none;
        cursor: pointer;
        width: fit-content;
    }

        .switch-wrapper * {
            cursor: pointer !important;
        }

    .switch-input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
    }

    .switch-slider {
        position: relative;
        width: 52px;
        height: 30px;
        border-radius: 999px;
        background: #d9d9d9;
        transition: background-color .25s ease, box-shadow .25s ease, transform .25s ease;
        box-shadow: inset 0 0 0 1px rgba(0,0,0,.06);
        flex-shrink: 0;
    }

        .switch-slider::before {
            content: "";
            position: absolute;
            top: 3px;
            left: 3px;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 2px 6px rgba(0,0,0,.18);
            transition: transform .25s ease;
        }

    .switch-input:checked + .switch-slider {
        background: var(--brand-primary);
    }

        .switch-input:checked + .switch-slider::before {
            transform: translateX(22px);
        }

    .switch-input:focus + .switch-slider {
        box-shadow: 0 0 0 .2rem rgba(159, 10, 16, .15);
    }

    .switch-text {
        display: flex;
        flex-direction: column;
        gap: .1rem;
    }

    .switch-title {
        font-size: .92rem;
        font-weight: 700;
        color: var(--brand-dark);
        line-height: 1.2;
    }

    .switch-subtitle {
        font-size: .78rem;
        color: var(--brand-muted);
        line-height: 1.35;
    }

    .switch-status {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: .22rem .6rem;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 700;
        background: rgba(108, 117, 125, .12);
        color: var(--brand-muted);
        transition: all .2s ease;
    }

        .switch-status.active {
            background: rgba(25, 135, 84, .12);
            color: var(--brand-success);
        }

    .brand-select-group {
        display: flex;
        gap: .75rem;
        align-items: stretch;
    }

        .brand-select-group .form-select {
            flex: 1 1 auto;
        }

    .accordion-clean .accordion-item {
        border: 1px solid var(--brand-border);
        border-radius: 1rem !important;
        overflow: hidden;
        margin-bottom: .85rem;
        background: #fff;
    }

    .accordion-clean .accordion-button {
        font-weight: 700;
        color: var(--brand-dark);
        background: #fff;
        box-shadow: none !important;
        padding: 1rem 1.1rem;
    }

        .accordion-clean .accordion-button:not(.collapsed) {
            color: var(--brand-primary);
            background: rgba(159, 10, 16, .04);
        }

    .accordion-clean .accordion-body {
        padding: 1rem 1.1rem 1.1rem;
    }

    .feature-toolbar {
        display: flex;
        justify-content: flex-end;
        gap: .65rem;
        margin-bottom: .9rem;
    }

    .feature-toolbar-global {
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
    }

    .feature-toolbar-note {
        font-size: .82rem;
        color: var(--brand-muted);
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .75rem;
    }

    .feature-check {
        display: flex;
        align-items: center;
        gap: .55rem;
        min-height: 44px;
        padding: .75rem .9rem;
        border: 1px solid #eee;
        border-radius: .85rem;
        background: #fff;
        transition: all .2s ease;
    }

        .feature-check:hover {
            background: #fafafa;
            border-color: #ddd;
        }

        .feature-check input[type="checkbox"] {
            transform: scale(1.08);
            accent-color: var(--brand-primary);
        }

        .feature-check label {
            font-size: .88rem;
            color: var(--brand-dark);
            cursor: pointer;
            margin: 0;
            width: 100%;
        }

    .media-dropzone {
        border: 2px dashed #d9d9d9;
        border-radius: 1rem;
        background: #fafafa;
        padding: 1.25rem;
        text-align: center;
        transition: all .2s ease;
    }

        .media-dropzone.dragover {
            border-color: var(--brand-primary);
            background: rgba(159, 10, 16, .04);
        }

    .media-dropzone-icon {
        font-size: 2rem;
        color: var(--brand-primary);
        margin-bottom: .4rem;
    }

    .media-dropzone-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin-bottom: .25rem;
    }

    .media-dropzone-subtitle {
        font-size: .84rem;
        color: var(--brand-muted);
        margin-bottom: .9rem;
    }

    .media-input-hidden {
        display: none;
    }

    .media-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .75rem;
        margin-top: 1rem;
        margin-bottom: .75rem;
        flex-wrap: wrap;
    }

    .media-sort-help {
        font-size: .8rem;
        color: var(--brand-muted);
    }

    .media-list {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-top: .75rem;
    }

    .media-item {
        border: 1px solid var(--brand-border);
        border-radius: 1rem;
        background: #fff;
        overflow: hidden;
        box-shadow: var(--brand-card-shadow);
        position: relative;
        cursor: grab;
    }

        .media-item.dragging {
            opacity: .55;
            transform: scale(.98);
        }

    .media-thumb {
        width: 100%;
        height: 180px;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .media-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .media-body {
        padding: .85rem;
    }

    .media-name {
        font-size: .82rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0 0 .45rem 0;
        word-break: break-word;
    }

    .media-meta {
        font-size: .76rem;
        color: var(--brand-muted);
        margin-bottom: .75rem;
    }

    .media-actions {
        display: flex;
        flex-direction: column;
        gap: .45rem;
    }

    .media-badge {
        position: absolute;
        top: .75rem;
        left: .75rem;
        z-index: 2;
        background: rgba(0,0,0,.65);
        color: #fff;
        font-size: .7rem;
        font-weight: 700;
        padding: .25rem .55rem;
        border-radius: 999px;
    }

    .media-remove-btn {
        width: 100%;
        border-radius: .75rem;
    }

    .media-order-label {
        font-size: .75rem;
        color: var(--brand-muted);
        font-weight: 700;
    }

    .input-with-prefix {
        position: relative;
    }

        .input-with-prefix .prefix {
            position: absolute;
            top: 50%;
            left: 14px;
            transform: translateY(-50%);
            font-size: .9rem;
            color: var(--brand-muted);
            font-weight: 700;
            pointer-events: none;
        }

        .input-with-prefix .form-control {
            padding-left: 40px;
        }

    .modal-content {
        border-radius: 1rem;
        border: 1px solid var(--brand-border);
        box-shadow: var(--brand-card-shadow);
    }

    .modal-header,
    .modal-footer {
        border-color: #f2f2f2;
    }

    @@media (max-width: 1200px) {
        .media-list {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 992px) {
        .feature-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .media-list {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .page-header,
        .form-actions,
        .media-toolbar,
        .brand-select-group {
            flex-direction: column;
            align-items: stretch;
        }

        .feature-grid,
        .media-list {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container-fluid">
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi @(isEdit ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                @(isEdit ? "Editar Veículo" : "Novo Veículo")
            </h1>
            <p class="page-subtitle">
                @(isEdit ? "Atualize os dados do veículo cadastrado" : "Preencha os dados para cadastrar um novo veículo")
            </p>
        </div>

        <a asp-page="./Index" class="btn btn-soft-dark">
            <i class="bi bi-arrow-left me-2"></i>
            Voltar
        </a>
    </div>

    <div class="form-card">
        <div class="form-card-body">
            <form method="post" enctype="multipart/form-data" id="formVeiculo">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Veiculo.Id" />
                <input type="hidden" asp-for="Veiculo.DataCadastro" />
                <input type="hidden" asp-for="Veiculo.Titulo" />
                <input type="hidden" asp-for="MidiasOrdenadasJson" id="MidiasOrdenadasJson" />
                <input type="hidden" asp-for="CapaItemKey" id="CapaItemKey" />
                <input type="hidden" name="NovaMarcaNome" id="NovaMarcaNome" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <div class="section-title">Dados principais</div>
                    <div class="section-subtitle">Informações básicas do veículo.</div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-4">
                            <label asp-for="Veiculo.LojaId" class="form-label">Loja</label>
                            <select asp-for="Veiculo.LojaId" asp-items="Model.Lojas" class="form-select">
                                <option value="">Selecione</option>
                            </select>
                            <span asp-validation-for="Veiculo.LojaId" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-8">
                            <label asp-for="Veiculo.MarcaId" class="form-label">Marca</label>
                            <div class="brand-select-group">
                                <select asp-for="Veiculo.MarcaId" asp-items="Model.Marcas" class="form-select" id="Veiculo_MarcaId">
                                    <option value="">Selecione</option>
                                </select>

                                <button type="button" style="display:none" class="btn btn-soft-primary" data-bs-toggle="modal" data-bs-target="#modalNovaMarca">
                                    <i class="bi bi-plus-circle me-2"></i>
                                    Cadastrar marca
                                </button>
                            </div>
                            <span asp-validation-for="Veiculo.MarcaId" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label asp-for="Veiculo.Modelo" class="form-label">Modelo</label>
                            <input asp-for="Veiculo.Modelo" class="form-control" maxlength="100" placeholder="Ex.: Onix" />
                            <span asp-validation-for="Veiculo.Modelo" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label asp-for="Veiculo.Versao" class="form-label">Versão</label>
                            <input asp-for="Veiculo.Versao" class="form-control" maxlength="100" placeholder="Ex.: LTZ" />
                            <span asp-validation-for="Veiculo.Versao" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Veiculo.AnoFabricacao" class="form-label">Ano fabricação</label>
                            <input asp-for="Veiculo.AnoFabricacao" class="form-control" type="number" placeholder="Ex.: 2022" />
                            <span asp-validation-for="Veiculo.AnoFabricacao" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Veiculo.AnoModelo" class="form-label">Ano modelo</label>
                            <input asp-for="Veiculo.AnoModelo" class="form-control" type="number" placeholder="Ex.: 2023" />
                            <span asp-validation-for="Veiculo.AnoModelo" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Veiculo.Cor" class="form-label">Cor</label>
                            <input asp-for="Veiculo.Cor" class="form-control" maxlength="30" placeholder="Ex.: Branco" />
                            <span asp-validation-for="Veiculo.Cor" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Veiculo.Quilometragem" class="form-label">Quilometragem</label>
                            <input asp-for="Veiculo.Quilometragem"
                                   class="form-control js-mask-km"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="15"
                                   placeholder="Ex.: 45.000" />
                            <span asp-validation-for="Veiculo.Quilometragem" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Veiculo.Combustivel" class="form-label">Combustível</label>
                            <select asp-for="Veiculo.Combustivel" class="form-select">
                                <option value="">Selecione</option>
                                <option value="Flex">Flex</option>
                                <option value="Gasolina">Gasolina</option>
                                <option value="Etanol">Etanol</option>
                                <option value="Diesel">Diesel</option>
                                <option value="Elétrico">Elétrico</option>
                                <option value="Híbrido">Híbrido</option>
                                <option value="GNV">GNV</option>
                            </select>
                            <span asp-validation-for="Veiculo.Combustivel" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label asp-for="Veiculo.Cambio" class="form-label">Câmbio</label>
                            <select asp-for="Veiculo.Cambio" class="form-select">
                                <option value="">Selecione</option>
                                <option value="Manual">Manual</option>
                                <option value="Automático">Automático</option>
                                <option value="CVT">CVT</option>
                                <option value="Automatizado">Automatizado</option>
                            </select>
                            <span asp-validation-for="Veiculo.Cambio" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="Veiculo.Placa" class="form-label">Placa</label>
                            <input asp-for="Veiculo.Placa"
                                   class="form-control js-mask-placa text-uppercase"
                                   maxlength="8"
                                   placeholder="ABC1D23" />
                            <span asp-validation-for="Veiculo.Placa" class="text-danger"></span>
                        </div>

                        <div class="col-12 col-md-4">
                            <label asp-for="Veiculo.PrecoVenda" class="form-label">Preço de venda</label>
                            <div class="input-with-prefix">
                                <span class="prefix">R$</span>
                                <input asp-for="Veiculo.PrecoVenda"
                                       class="form-control js-mask-money"
                                       type="text"
                                       inputmode="decimal"
                                       placeholder="0,00" />
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="Veiculo.Descricao" class="form-label">Descrição</label>
                            <textarea asp-for="Veiculo.Descricao" class="form-control" maxlength="1000" placeholder="Descreva os detalhes do veículo..."></textarea>
                            <span asp-validation-for="Veiculo.Descricao" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="mb-4">
                    <div class="section-title">Status e flags</div>
                    <div class="section-subtitle">Defina disponibilidade e condições comerciais.</div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="switch-field">
                                <label class="switch-wrapper" for="Veiculo_Ativo">
                                    <input asp-for="Veiculo.Ativo" class="switch-input" id="Veiculo_Ativo" type="checkbox" />
                                    <span class="switch-slider"></span>
                                    <span class="switch-text">
                                        <span class="switch-title">Ativo</span>
                                        <span class="switch-subtitle">Veículo disponível no sistema.</span>
                                    </span>
                                </label>
                                <span id="statusVeiculoAtivo" class="switch-status">Inativo</span>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="switch-field">
                                <label class="switch-wrapper" for="Veiculo_Vendido">
                                    <input asp-for="Veiculo.Vendido" class="switch-input" id="Veiculo_Vendido" type="checkbox" />
                                    <span class="switch-slider"></span>
                                    <span class="switch-text">
                                        <span class="switch-title">Vendido</span>
                                        <span class="switch-subtitle">Marca o veículo como vendido.</span>
                                    </span>
                                </label>
                                <span id="statusVeiculoVendido" class="switch-status">Não</span>
                                @if (Model.Veiculo.Vendido)
                                {
                                    var usuarioBaixa = !string.IsNullOrWhiteSpace(Model.Veiculo.VendidoPorUsuario?.NomeCompleto)
                                        ? Model.Veiculo.VendidoPorUsuario?.NomeCompleto
                                        : Model.Veiculo.VendidoPorUsuario?.UserName;

                                    <small class="form-help">
                                        Data da venda: @(Model.Veiculo.DataVenda.HasValue ? Model.Veiculo.DataVenda.Value.ToString("dd/MM/yyyy HH:mm") : "-")
                                        <br />
                                        Baixa registrada por: @(string.IsNullOrWhiteSpace(usuarioBaixa) ? "-" : usuarioBaixa)
                                    </small>
                                }
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="switch-field">
                                <label class="switch-wrapper" for="Veiculo_Destaque">
                                    <input asp-for="Veiculo.Destaque" class="switch-input" id="Veiculo_Destaque" type="checkbox" />
                                    <span class="switch-slider"></span>
                                    <span class="switch-text">
                                        <span class="switch-title">Destaque</span>
                                        <span class="switch-subtitle">Prioriza o veículo na vitrine.</span>
                                    </span>
                                </label>
                                <span id="statusVeiculoDestaque" class="switch-status">Não</span>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <div class="switch-field">
                                <label class="switch-wrapper" for="Veiculo_Seminovo">
                                    <input asp-for="Veiculo.Seminovo" class="switch-input" id="Veiculo_Seminovo" type="checkbox" />
                                    <span class="switch-slider"></span>
                                    <span class="switch-text">
                                        <span class="switch-title">Seminovo</span>
