@page
@model Concessionaria.Pages.Veiculo.ImportaJSONModel
@using System.Globalization
@{
    ViewData["Title"] = "Importacao JSON";
    ViewData["TopbarTitle"] = "Importacao JSON";
    ViewData["TopbarSubtitle"] = "Importacao unificada de veiculos e midias do legado";
    Layout = "_LayoutAdmin";

    var culture = new CultureInfo("pt-BR");
}

<style>
    :root {
        --import-brand: #9f0a10;
        --import-brand-dark: #7f0810;
        --import-border: #ececec;
        --import-text: #1d1d1d;
        --import-muted: #667085;
        --import-card-shadow: 0 10px 30px rgba(0,0,0,.05);
        --import-error-bg: #fff1f2;
        --import-error-border: #fecdd3;
        --import-success-bg: #ecfdf3;
        --import-success-border: #bbf7d0;
    }

    .import-shell { display: grid; gap: 1.25rem; }
    .import-card { background: #fff; border: 1px solid var(--import-border); border-radius: 1rem; box-shadow: var(--import-card-shadow); overflow: hidden; }
    .import-card-header { padding: 1.15rem 1.2rem 1rem; border-bottom: 1px solid var(--import-border); background: linear-gradient(180deg, #fff 0%, #fff8f8 100%); }
    .import-card-title { margin: 0; font-size: 1.05rem; font-weight: 700; color: var(--import-text); }
    .import-card-subtitle { margin: .25rem 0 0; color: var(--import-muted); font-size: .9rem; }
    .import-card-body { padding: 1.2rem; }
    .import-upload { border: 1px dashed #d6d6d6; border-radius: 1rem; padding: 1rem; background: linear-gradient(180deg, #fff 0%, #fcfcfc 100%); }
    .import-file { border-radius: .85rem; min-height: 46px; }
    .import-helper { margin-top: .85rem; color: var(--import-muted); font-size: .88rem; line-height: 1.5; }
    .import-actions { display: flex; justify-content: flex-end; gap: .75rem; flex-wrap: wrap; margin-top: 1rem; }
    .import-btn-primary, .import-btn-secondary { min-height: 46px; border-radius: .85rem; padding: 0 1.2rem; font-weight: 600; border: none; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .import-btn-primary { background: linear-gradient(135deg, var(--import-brand) 0%, var(--import-brand-dark) 100%); color: #fff; }
    .import-btn-secondary { background: #fff; color: var(--import-text); border: 1px solid var(--import-border); }
    .import-alert { border-radius: .85rem; padding: .95rem 1rem; margin-bottom: 1rem; font-size: .92rem; }
    .import-alert-danger { background: var(--import-error-bg); border: 1px solid var(--import-error-border); color: #9f1239; }
    .import-alert-success { background: var(--import-success-bg); border: 1px solid var(--import-success-border); color: #166534; }
    .import-summary { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; margin-bottom: 1rem; }
    .import-box { border: 1px solid #efe7e8; background: #fff8f8; border-radius: .9rem; padding: .95rem; }
    .import-box-label { display: block; margin-bottom: .3rem; font-size: .74rem; font-weight: 800; text-transform: uppercase; letter-spacing: .05em; color: var(--import-muted); }
    .import-box-value { font-size: 1rem; font-weight: 700; color: var(--import-text); }
    .import-table { width: 100%; border-collapse: collapse; }
    .import-table th, .import-table td { padding: .85rem .8rem; border-bottom: 1px solid #f1f1f1; vertical-align: top; }
    .import-table th { font-size: .78rem; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; color: var(--import-muted); background: #fafafa; }
    .import-status { display: inline-flex; align-items: center; border-radius: 999px; padding: .2rem .55rem; font-size: .75rem; font-weight: 700; }
    .import-status-ok { background: #dcfce7; color: #166534; }
    .import-status-error { background: #ffe4e6; color: #be123c; }
    .import-errors { margin: 0; padding-left: 1rem; color: #9f1239; }
    .import-raw { max-height: 280px; overflow: auto; margin-top: 1rem; border-radius: .9rem; background: #111827; color: #e5e7eb; padding: 1rem; font-size: .86rem; }
    .import-photos { font-size: .82rem; color: var(--import-muted); line-height: 1.45; }

    @@media (max-width: 992px) { .import-summary { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @@media (max-width: 768px) { .import-summary { grid-template-columns: 1fr; } }
</style>

<div class="container-fluid import-shell">
    <section class="import-card">
        <div class="import-card-header">
            <h1 class="import-card-title">Importacao unificada</h1>
            <p class="import-card-subtitle">Envie um unico JSON com dados do veiculo e fotos do legado.</p>
        </div>
        <div class="import-card-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="import-alert import-alert-danger"></div>
            }

            <form method="post" asp-page-handler="Preview" enctype="multipart/form-data">
                <div class="import-upload">
                    <input asp-for="Input.JsonFile" type="file" accept=".json,application/json" class="form-control import-file" />

                    <div class="import-helper">
                        O arquivo pode conter um objeto ou uma lista de objetos no formato com <code>dadosAdmin</code> e <code>midias.fotos</code>.
                        A previa valida id legado, loja, marca, placa, parse de valor/ano/KM/data e a consistencia das fotos antes de importar.
                    </div>
                </div>

                <div class="import-actions">
                    <a asp-page="./Index" class="import-btn-secondary">Voltar</a>
                    <button type="submit" class="import-btn-primary">Gerar previa</button>
                </div>
            </form>
        </div>
    </section>

    @if (Model.Preview != null)
    {
        <section class="import-card">
            <div class="import-card-header">
                <h2 class="import-card-title">Previa da importacao</h2>
                <p class="import-card-subtitle">Os registros validos serao importados com cadastro, opcionais e midias em uma unica operacao.</p>
            </div>
            <div class="import-card-body">
                @if (Model.Preview.CanImport)
                {
                    <div class="import-alert import-alert-success">Existem registros prontos para importacao.</div>
                }
                else
                {
                    <div class="import-alert import-alert-danger">Nenhum registro valido foi encontrado para importacao.</div>
                }

                <div class="import-summary">
                    <div class="import-box">
                        <span class="import-box-label">Registros</span>
                        <div class="import-box-value">@Model.Preview.Items.Count</div>
                    </div>
                    <div class="import-box">
                        <span class="import-box-label">Validos</span>
                        <div class="import-box-value">@Model.Preview.Items.Count(x => x.CanImport)</div>
                    </div>
                    <div class="import-box">
                        <span class="import-box-label">Com erro</span>
                        <div class="import-box-value">@Model.Preview.Items.Count(x => !x.CanImport)</div>
                    </div>
                    <div class="import-box">
                        <span class="import-box-label">Fotos</span>
                        <div class="import-box-value">@Model.Preview.Items.Sum(x => x.Fotos.Count)</div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="import-table">
                        <thead>
                            <tr>
                                <th>Legado</th>
                                <th>Titulo</th>
                                <th>Loja / Marca</th>
                                <th>Ano / KM / Preco</th>
                                <th>Midias</th>
                                <th>Status</th>
                                <th>Erros</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Preview.Items)
                        {
                            <tr>
                                <td>@item.IdLegado</td>
                                <td>
                                    <strong>@item.Titulo</strong><br />
                                    <span class="text-muted">@(item.Placa ?? "-")</span>
                                </td>
                                <td>
                                    @(item.Loja?.Nome ?? item.LojaNome ?? "-")<br />
                                    <span class="text-muted">@(item.Marca?.Nome ?? item.MarcaNome ?? "-")</span>
                                </td>
                                <td>
                                    @($"{item.AnoFabricacao?.ToString() ?? "-"} / {item.AnoModelo?.ToString() ?? "-"}")<br />
                                    <span class="text-muted">@(item.Quilometragem.HasValue ? $"{item.Quilometragem.Value:N0} km" : "-")</span><br />
                                    <span class="text-muted">@(item.PrecoVenda.HasValue && item.PrecoVenda.Value > 0m ? item.PrecoVenda.Value.ToString("C", culture) : "Consulte")</span>
                                </td>
                                <td class="import-photos">
                                    Informado: @item.TotalFotosInformado<br />
                                    Lido: @item.Fotos.Count<br />
                                    Capa: @(item.Fotos.Count(x => x.Capa))
                                </td>
                                <td>
                                    @if (item.CanImport)
                                    {
                                        <span class="import-status import-status-ok">Pronto</span>
                                    }
                                    else
                                    {
                                        <span class="import-status import-status-error">Bloqueado</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Errors.Count == 0)
                                    {
                                        <span class="text-success fw-semibold">Sem pendencias</span>
                                    }
                                    else
                                    {
                                        <ul class="import-errors">
                                            @foreach (var error in item.Errors.Distinct())
                                            {
                                                <li>@error</li>
                                            }
                                        </ul>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <form method="post" asp-page-handler="Import" class="mt-4">
                    <textarea asp-for="Input.RawJson" hidden></textarea>
                    <div class="import-actions">
                        <button type="submit" class="import-btn-primary" @(Model.Preview.CanImport ? null : "disabled")>Importar registros</button>
                    </div>
                </form>

                <details class="mt-3">
                    <summary class="fw-semibold">Ver JSON carregado</summary>
                    <pre class="import-raw">@Model.Preview.RawJson</pre>
                </details>
            </div>
        </section>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
