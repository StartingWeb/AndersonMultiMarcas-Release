@page
@model Concessionaria.Pages.Veiculo.ImportaMidiaModel
@{
    ViewData["Title"] = "Importa Midia";
    ViewData["TopbarTitle"] = "Importa Midia";
    ViewData["TopbarSubtitle"] = "Importação de fotos legadas dos veículos";
    Layout = "_LayoutAdmin";
}

<style>
    :root {
        --midia-brand: #9f0a10;
        --midia-brand-dark: #7f0810;
        --midia-border: #ececec;
        --midia-text: #1d1d1d;
        --midia-muted: #667085;
        --midia-card-shadow: 0 10px 30px rgba(0,0,0,.05);
        --midia-error-bg: #fff1f2;
        --midia-error-border: #fecdd3;
        --midia-success-bg: #ecfdf3;
        --midia-success-border: #bbf7d0;
    }

    .midia-shell { display: grid; gap: 1.25rem; }
    .midia-card { background: #fff; border: 1px solid var(--midia-border); border-radius: 1rem; box-shadow: var(--midia-card-shadow); overflow: hidden; }
    .midia-card-header { padding: 1.15rem 1.2rem 1rem; border-bottom: 1px solid var(--midia-border); background: linear-gradient(180deg, #fff 0%, #fff8f8 100%); }
    .midia-card-title { margin: 0; font-size: 1.05rem; font-weight: 700; color: var(--midia-text); }
    .midia-card-subtitle { margin: .25rem 0 0; color: var(--midia-muted); font-size: .9rem; }
    .midia-card-body { padding: 1.2rem; }
    .midia-upload { border: 1px dashed #d6d6d6; border-radius: 1rem; padding: 1rem; background: linear-gradient(180deg, #fff 0%, #fcfcfc 100%); }
    .midia-file { border-radius: .85rem; min-height: 46px; }
    .midia-helper { margin-top: .85rem; color: var(--midia-muted); font-size: .88rem; line-height: 1.5; }
    .midia-actions { display: flex; justify-content: flex-end; gap: .75rem; flex-wrap: wrap; margin-top: 1rem; }
    .midia-btn-primary, .midia-btn-secondary { min-height: 46px; border-radius: .85rem; padding: 0 1.2rem; font-weight: 600; border: none; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .midia-btn-primary { background: linear-gradient(135deg, var(--midia-brand) 0%, var(--midia-brand-dark) 100%); color: #fff; }
    .midia-btn-secondary { background: #fff; color: var(--midia-text); border: 1px solid var(--midia-border); }
    .midia-alert { border-radius: .85rem; padding: .95rem 1rem; margin-bottom: 1rem; font-size: .92rem; }
    .midia-alert-danger { background: var(--midia-error-bg); border: 1px solid var(--midia-error-border); color: #9f1239; }
    .midia-alert-success { background: var(--midia-success-bg); border: 1px solid var(--midia-success-border); color: #166534; }
    .midia-summary { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; margin-bottom: 1rem; }
    .midia-box { border: 1px solid #efe7e8; background: #fff8f8; border-radius: .9rem; padding: .95rem; }
    .midia-box-label { display: block; margin-bottom: .3rem; font-size: .74rem; font-weight: 800; text-transform: uppercase; letter-spacing: .05em; color: var(--midia-muted); }
    .midia-box-value { font-size: 1rem; font-weight: 700; color: var(--midia-text); }
    .midia-item { border: 1px solid #f0f0f0; border-radius: 1rem; padding: 1rem; }
    .midia-item + .midia-item { margin-top: 1rem; }
    .midia-item-head { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: .75rem; }
    .midia-title { font-size: 1rem; font-weight: 700; color: var(--midia-text); margin: 0; }
    .midia-sub { color: var(--midia-muted); font-size: .88rem; }
    .midia-status-badge { display: inline-flex; align-items: center; border-radius: 999px; padding: .2rem .55rem; font-size: .75rem; font-weight: 700; }
    .midia-status-ok { background: #dcfce7; color: #166534; }
    .midia-status-error { background: #ffe4e6; color: #be123c; }
    .midia-errors { margin: .6rem 0 0; padding-left: 1rem; color: #9f1239; }
    .midia-table { width: 100%; border-collapse: collapse; }
    .midia-table th, .midia-table td { padding: .75rem .7rem; border-bottom: 1px solid #f1f1f1; vertical-align: top; }
    .midia-table th { font-size: .75rem; text-transform: uppercase; letter-spacing: .04em; color: var(--midia-muted); background: #fafafa; }
    .midia-code { font-family: Consolas, monospace; font-size: .82rem; word-break: break-all; }
    .midia-raw { max-height: 280px; overflow: auto; margin-top: 1rem; border-radius: .9rem; background: #111827; color: #e5e7eb; padding: 1rem; font-size: .86rem; }

    @@media (max-width: 992px) {
        .midia-summary { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 768px) {
        .midia-summary { grid-template-columns: 1fr; }
    }
</style>

<div class="container-fluid midia-shell">
    <section class="midia-card">
        <div class="midia-card-header">
            <h1 class="midia-card-title">Importa Midia</h1>
            <p class="midia-card-subtitle">Envie o JSON legado das fotos. O importador localiza o veículo pelo `idLegado`, copia os arquivos físicos e registra as mídias no banco.</p>
        </div>
        <div class="midia-card-body">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="midia-alert midia-alert-danger"></div>
            }

            <form method="post" asp-page-handler="Preview" enctype="multipart/form-data">
                <div class="midia-upload">
                    <input asp-for="Input.JsonFile" type="file" accept=".json,application/json" class="form-control midia-file" />

                    <div class="midia-helper">
                        Validações aplicadas: `idLegado` obrigatório, veículo existente pelo legado, lista de fotos obrigatória,
                        capa válida, ordem sem duplicidade, nome de arquivo sem duplicidade, arquivo físico existente e bloqueio
                        quando o veículo já tiver mídia cadastrada com o mesmo nome ou ordem.
                    </div>
                </div>

                <div class="midia-actions">
                    <a asp-page="./Index" class="midia-btn-secondary">Voltar</a>
                    <button type="submit" class="midia-btn-primary">Gerar prévia</button>
                </div>
            </form>
        </div>
    </section>

    @if (Model.Preview != null)
    {
        <section class="midia-card">
            <div class="midia-card-header">
                <h2 class="midia-card-title">Prévia da importação</h2>
                <p class="midia-card-subtitle">As fotos só são importadas quando todos os registros estiverem válidos.</p>
            </div>
            <div class="midia-card-body">
                @if (Model.Preview.CanImport)
                {
                    <div class="midia-alert midia-alert-success">
                        Prévia válida. Os arquivos serão copiados para `wwwroot/uploads/veiculos/{id}` e já ficarão prontos para o site.
                    </div>
                }
                else
                {
                    <div class="midia-alert midia-alert-danger">
                        Existem pendências na importação das mídias. Corrija o JSON ou os arquivos físicos antes de continuar.
                    </div>
                }

                <div class="midia-summary">
                    <div class="midia-box">
                        <span class="midia-box-label">Registros</span>
                        <div class="midia-box-value">@Model.Preview.Items.Count</div>
                    </div>
                    <div class="midia-box">
                        <span class="midia-box-label">Válidos</span>
                        <div class="midia-box-value">@Model.Preview.Items.Count(x => x.CanImport)</div>
                    </div>
                    <div class="midia-box">
                        <span class="midia-box-label">Fotos</span>
                        <div class="midia-box-value">@Model.Preview.Items.Sum(x => x.Fotos.Count)</div>
                    </div>
                    <div class="midia-box">
                        <span class="midia-box-label">Com erro</span>
                        <div class="midia-box-value">@Model.Preview.Items.Count(x => !x.CanImport)</div>
                    </div>
                </div>

                @foreach (var item in Model.Preview.Items)
                {
                    <section class="midia-item">
                        <div class="midia-item-head">
                            <div>
                                <h3 class="midia-title">@(item.VeiculoTitulo ?? item.TituloLegado ?? $"Legado {item.IdLegado}")</h3>
                                <div class="midia-sub">Id legado: @item.IdLegado | Veículo: @(item.VeiculoId > 0 ? $"#{item.VeiculoId}" : "-") | Fotos: @item.Fotos.Count</div>
                                <div class="midia-sub">Destino: <span class="midia-code">@item.DestinoPastaFisica</span></div>
                            </div>
                            <div>
                                @if (item.CanImport)
                                {
                                    <span class="midia-status-badge midia-status-ok">Pronto</span>
                                }
                                else
                                {
                                    <span class="midia-status-badge midia-status-error">Bloqueado</span>
                                }
                            </div>
                        </div>

                        @if (item.Errors.Count > 0)
                        {
                            <ul class="midia-errors">
                                @foreach (var error in item.Errors.Distinct())
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        }

                        <div class="table-responsive mt-3">
                            <table class="midia-table">
                                <thead>
                                    <tr>
                                        <th>Ordem</th>
                                        <th>Arquivo</th>
                                        <th>Capa</th>
                                        <th>Origem</th>
                                        <th>Destino</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var foto in item.Fotos)
                                {
                                    <tr>
                                        <td>@(foto.Ordem?.ToString() ?? "-")</td>
                                        <td>
                                            <div>@foto.NomeArquivo</div>
                                            @if (foto.Errors.Count > 0)
                                            {
                                                <ul class="midia-errors">
                                                    @foreach (var error in foto.Errors)
                                                    {
                                                        <li>@error</li>
                                                    }
                                                </ul>
                                            }
                                        </td>
                                        <td>@(foto.Capa ? "Sim" : "Não")</td>
                                        <td><span class="midia-code">@foto.CaminhoCompleto</span></td>
                                        <td><span class="midia-code">@foto.UrlDestino</span></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }

                <form method="post" asp-page-handler="Import" class="mt-4">
                    <textarea asp-for="Input.RawJson" hidden></textarea>

                    <div class="midia-actions">
                        <button type="submit" class="midia-btn-primary" @(Model.Preview.CanImport ? null : "disabled")>Importar mídias</button>
                    </div>
                </form>

                <details class="mt-3">
                    <summary class="fw-semibold">Ver JSON carregado</summary>
                    <pre class="midia-raw">@Model.Preview.RawJson</pre>
                </details>
            </div>
        </section>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
