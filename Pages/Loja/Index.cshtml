@page
@model Concessionaria.Pages.Loja.IndexModel
@{
    ViewData["Title"] = "Lojas";
    ViewData["TopbarTitle"] = "Lojas";
    ViewData["TopbarSubtitle"] = "Gerencie as unidades cadastradas";
    Layout = "_LayoutAdmin";

    var lojas = Model.Lojas ?? new List<Core.Dtos.LojaDto>();
    var totalLojas = lojas.Count();
}

<style>
    :root {
        --brand-primary: #9f0a10;
        --brand-dark: #222222;
        --brand-border: #ececec;
        --brand-muted: #6c757d;
        --brand-soft: rgba(159, 10, 16, 0.08);
        --brand-success: #198754;
        --brand-danger: #dc3545;
        --brand-danger-soft: rgba(220, 53, 69, 0.08);
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .page-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0;
    }

    .page-subtitle {
        font-size: .88rem;
        color: var(--brand-muted);
        margin: .15rem 0 0 0;
    }

    .search-card {
        background: #fff;
        border: 1px solid var(--brand-border);
        border-radius: .9rem;
        box-shadow: 0 6px 18px rgba(0,0,0,.04);
        margin-bottom: 1rem;
    }

    .search-card .card-body {
        padding: .9rem;
    }

    .filter-label {
        font-size: .78rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin-bottom: .35rem;
    }

    .form-control,
    .form-select {
        border-radius: .75rem;
        border: 1px solid #e6e6e6;
        min-height: 42px;
        box-shadow: none !important;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: rgba(159, 10, 16, .35);
        box-shadow: 0 0 0 .2rem rgba(159, 10, 16, .08) !important;
    }

    .input-icon-wrap {
        position: relative;
    }

    .input-icon-wrap i {
        position: absolute;
        left: .9rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--brand-muted);
        font-size: .95rem;
    }

    .input-icon-wrap .form-control {
        padding-left: 2.4rem;
    }

    .btn-brand {
        background: var(--brand-primary);
        border-color: var(--brand-primary);
        color: #fff;
        border-radius: .75rem;
        font-weight: 600;
        min-height: 42px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .btn-brand:hover {
        background: #86080d;
        border-color: #86080d;
        color: #fff;
    }

    .btn-soft-dark {
        background: #fff;
        border: 1px solid var(--brand-border);
        color: var(--brand-dark);
        border-radius: .75rem;
        font-weight: 600;
        min-height: 42px;
    }

    .btn-soft-dark:hover {
        background: #f8f8f8;
        color: var(--brand-dark);
    }

    .results-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: .9rem;
    }

    .results-title {
        font-size: .98rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0;
    }

    .results-counter {
        font-size: .88rem;
        color: var(--brand-muted);
    }

    .list-card {
        background: #fff;
        border: 1px solid var(--brand-border);
        border-radius: 1rem;
        box-shadow: 0 8px 24px rgba(0,0,0,.05);
        overflow: hidden;
    }

    .store-table {
        margin: 0;
        vertical-align: middle;
    }

    .store-table thead th {
        background: #f8f8f8;
        color: var(--brand-dark);
        font-size: .76rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .04em;
        border-bottom: 1px solid var(--brand-border);
        padding: 1rem .9rem;
        white-space: nowrap;
    }

    .store-table tbody td {
        padding: 1rem .9rem;
        border-color: #f1f1f1;
        color: var(--brand-dark);
    }

    .store-name-cell {
        display: flex;
        align-items: center;
        gap: .85rem;
        min-width: 240px;
    }

    .store-avatar {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(159, 10, 16, .12), rgba(159, 10, 16, .04));
        color: var(--brand-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .store-name {
        font-size: .95rem;
        font-weight: 700;
        line-height: 1.3;
        margin: 0 0 .12rem;
    }

    .store-id {
        font-size: .82rem;
        color: var(--brand-muted);
    }

    .store-muted {
        color: var(--brand-muted);
        font-size: .88rem;
    }

    .store-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: .38rem .7rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .store-badge.active {
        background: rgba(25, 135, 84, .10);
        color: var(--brand-success);
    }

    .store-badge.inactive {
        background: var(--brand-danger-soft);
        color: var(--brand-danger);
    }

    .table-action {
        min-width: 120px;
    }

    .empty-state {
        border: 1px dashed #dadada;
        border-radius: 1rem;
        padding: 2.2rem 1.2rem;
        text-align: center;
        background: #fff;
    }

    .empty-state-icon {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        margin: 0 auto .9rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--brand-soft);
        color: var(--brand-primary);
        font-size: 1.6rem;
    }

    @@media (max-width: 768px) {
        .page-header,
        .results-topbar {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

<div class="container-fluid store-page">

    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi bi-shop-window me-2"></i>
                Lojas
            </h1>
            <p class="page-subtitle">Lista e gerenciamento das unidades cadastradas</p>
        </div>

        <a href="/Loja/Upsert" class="btn btn-brand px-3">
            <i class="bi bi-plus-circle me-2"></i>
            Nova loja
        </a>
    </div>

    <div class="search-card card">
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-12 col-xl-6">
                        <label class="filter-label">Pesquisar loja</label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-search"></i>
                            <input type="text"
                                   name="Filtro"
                                   value="@Model.Filtro"
                                   class="form-control"
                                   placeholder="Digite nome, cidade, telefone ou e-mail..." />
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label">Ordenação</label>
                        <select name="Ordem" class="form-select">
                            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Ordem))">Nome (A-Z)</option>
                            <option value="nome_desc" selected="@(Model.Ordem == "nome_desc")">Nome (Z-A)</option>
                            <option value="cidade" selected="@(Model.Ordem == "cidade")">Cidade</option>
                            <option value="recentes" selected="@(Model.Ordem == "recentes")">Mais recentes</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-6 col-xl-3">
                        <label class="filter-label d-none d-md-block">&nbsp;</label>
                        <div class="d-grid gap-2 d-md-flex">
                            <button type="submit" class="btn btn-brand flex-fill">
                                <i class="bi bi-search me-2"></i>
                                Buscar
                            </button>

                            <a asp-page="./Index" class="btn btn-soft-dark flex-fill">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>
                                Limpar
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="results-topbar">
        <h5 class="results-title">Lojas cadastradas</h5>
        <div class="results-counter">
            <strong>@totalLojas</strong> registro(s)
        </div>
    </div>

    @if (lojas.Any())
    {
        <div class="list-card">
            <div class="table-responsive">
                <table class="table store-table admin-responsive-table">
                    <thead>
                        <tr>
                            <th>Loja</th>
                            <th>Status</th>
                            <th>Cidade</th>
                            <th>Telefone</th>
                            <th>E-mail</th>
                            <th class="text-end">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var loja in lojas)
                        {
                            var cidadeUf = string.Join(" / ", new[]
                            {
                                Convert.ToString(loja.Cidade),
                                Convert.ToString(loja.Uf)
                            }.Where(x => !string.IsNullOrWhiteSpace(x)));

                            <tr>
                                <td data-label="Loja">
                                    <div class="store-name-cell">
                                        <div class="store-avatar">
                                            <i class="bi bi-shop"></i>
                                        </div>
                                        <div>
                                            <div class="store-name">@loja.Nome</div>
                                            <div class="store-id">ID #@loja.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td data-label="Status">
                                    <span class="store-badge @(loja.Ativo ? "active" : "inactive")">
                                        @(loja.Ativo ? "Ativa" : "Inativa")
                                    </span>
                                </td>
                                <td data-label="Cidade">
                                    <span class="store-muted">@(string.IsNullOrWhiteSpace(cidadeUf) ? "Não informada" : cidadeUf)</span>
                                </td>
                                <td data-label="Telefone">
                                    <span class="store-muted">@(string.IsNullOrWhiteSpace(Convert.ToString(loja.Telefone)) ? "Não informado" : loja.Telefone)</span>
                                </td>
                                <td data-label="E-mail">
                                    <span class="store-muted">@(string.IsNullOrWhiteSpace(Convert.ToString(loja.Email)) ? "Não informado" : loja.Email)</span>
                                </td>
                                <td class="text-end" data-label="Ação">
                                    <a asp-page="./Upsert" asp-route-id="@loja.Id" class="btn btn-brand table-action">
                                        <i class="bi bi-pencil-square me-2"></i>
                                        Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-shop-window"></i>
            </div>

            <h5 class="fw-bold mb-2">Nenhuma loja encontrada</h5>
            <p class="text-muted mb-4">
                Não encontramos registros com os filtros informados.
            </p>

            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <a asp-page="./Index" class="btn btn-soft-dark">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>
                    Limpar filtros
                </a>

                <a asp-page="/Loja/Upsert" class="btn btn-brand">
                    <i class="bi bi-plus-circle me-2"></i>
                    Cadastrar loja
                </a>
            </div>
        </div>
    }
</div>
