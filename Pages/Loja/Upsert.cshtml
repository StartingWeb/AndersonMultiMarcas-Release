@page "{id:int?}"
@model Concessionaria.Pages.Loja.UpsertModel
@{
    var isEdit = Model.Loja.Id > 0;

    ViewData["Title"] = isEdit ? "Editar Loja" : "Nova Loja";
    ViewData["TopbarTitle"] = isEdit ? "Editar Loja" : "Nova Loja";
    ViewData["TopbarSubtitle"] = isEdit ? "Atualize os dados da unidade" : "Cadastre uma nova unidade";
    Layout = "_LayoutAdmin";
}

<style>
    :root {
        --brand-primary: #9f0a10;
        --brand-dark: #222222;
        --brand-border: #ececec;
        --brand-muted: #6c757d;
        --brand-soft: rgba(159, 10, 16, 0.08);
        --brand-success: #198754;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .page-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0;
    }

    .page-subtitle {
        font-size: .92rem;
        color: var(--brand-muted);
        margin: .2rem 0 0 0;
    }

    .form-card {
        background: #fff;
        border: 1px solid var(--brand-border);
        border-radius: 1rem;
        box-shadow: 0 8px 24px rgba(0,0,0,.05);
        overflow: hidden;
    }

    .form-card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f2f2f2;
        display: flex;
        align-items: center;
        gap: .75rem;
    }

    .form-card-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: var(--brand-soft);
        color: var(--brand-primary);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .form-card-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin: 0;
    }

    .form-card-subtitle {
        font-size: .85rem;
        color: var(--brand-muted);
        margin: 0;
    }

    .form-card-body {
        padding: 1.25rem;
    }

    .section-title {
        font-size: .98rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin-bottom: 1rem;
    }

    .form-label {
        font-size: .84rem;
        font-weight: 700;
        color: var(--brand-dark);
        margin-bottom: .35rem;
    }

    .form-help {
        display: block;
        font-size: .78rem;
        color: var(--brand-muted);
        margin-top: .4rem;
        line-height: 1.35;
    }

    .form-control,
    .form-select {
        border-radius: .85rem;
        border: 1px solid #e6e6e6;
        min-height: 46px;
        box-shadow: none !important;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: rgba(159, 10, 16, .35);
            box-shadow: 0 0 0 .2rem rgba(159, 10, 16, .08) !important;
        }

    .text-danger {
        font-size: .8rem;
    }

    .alert-brand-danger {
        background: rgba(220, 53, 69, 0.08);
        border: 1px solid rgba(220, 53, 69, 0.15);
        color: #842029;
        border-radius: .85rem;
        padding: .9rem 1rem;
        margin-bottom: 1rem;
    }

    .alert-brand-info {
        background: rgba(13, 110, 253, 0.08);
        border: 1px solid rgba(13, 110, 253, 0.15);
        color: #084298;
        border-radius: .85rem;
        padding: .75rem 1rem;
        margin-top: .75rem;
        display: none;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: .75rem;
        padding-top: 1.25rem;
        border-top: 1px solid #f2f2f2;
        margin-top: 1.25rem;
    }

    .btn-brand {
        background: var(--brand-primary);
        border-color: var(--brand-primary);
        color: #fff;
        border-radius: .85rem;
        font-weight: 600;
        min-height: 46px;
        padding: 0 1.25rem;
    }

        .btn-brand:hover {
            background: #86080d;
            border-color: #86080d;
            color: #fff;
        }

    .btn-soft-dark {
        background: #fff;
        border: 1px solid var(--brand-border);
        color: var(--brand-dark);
        border-radius: .85rem;
        font-weight: 600;
        min-height: 46px;
        padding: 0 1.25rem;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .btn-soft-dark:hover {
            background: #f8f8f8;
            color: var(--brand-dark);
        }

    .field-block {
        display: flex;
        flex-direction: column;
    }

    /* SWITCH CUSTOMIZADO */
    .switch-field {
        display: flex;
        flex-direction: column;
        gap: .45rem;
    }

    .switch-wrapper {
        display: inline-flex;
        align-items: center;
        gap: .75rem;
        user-select: none;
        cursor: pointer;
        width: fit-content;
    }

        .switch-wrapper * {
            cursor: pointer !important;
        }

    .switch-input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
    }

    .switch-slider {
        position: relative;
        width: 52px;
        height: 30px;
        border-radius: 999px;
        background: #d9d9d9;
        transition: background-color .25s ease, box-shadow .25s ease, transform .25s ease;
        box-shadow: inset 0 0 0 1px rgba(0,0,0,.06);
        flex-shrink: 0;
    }

        .switch-slider::before {
            content: "";
            position: absolute;
            top: 3px;
            left: 3px;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 2px 6px rgba(0,0,0,.18);
            transition: transform .25s ease;
        }

    .switch-input:checked + .switch-slider {
        background: var(--brand-primary);
    }

        .switch-input:checked + .switch-slider::before {
            transform: translateX(22px);
        }

    .switch-input:focus + .switch-slider {
        box-shadow: 0 0 0 .2rem rgba(159, 10, 16, .15);
    }

    .switch-text {
        display: flex;
        flex-direction: column;
        gap: .1rem;
    }

    .switch-title {
        font-size: .92rem;
        font-weight: 700;
        color: var(--brand-dark);
        line-height: 1.2;
    }

    .switch-subtitle {
        font-size: .78rem;
        color: var(--brand-muted);
        line-height: 1.35;
    }

    .switch-status {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: .22rem .6rem;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 700;
        background: rgba(108, 117, 125, .12);
        color: var(--brand-muted);
        transition: all .2s ease;
    }

        .switch-status.active {
            background: rgba(25, 135, 84, .12);
            color: var(--brand-success);
        }

    @@media (max-width: 768px) {
        .page-header,
        .form-actions {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>

<div class="container-fluid store-form-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">
                <i class="bi @(isEdit ? "bi-pencil-square" : "bi-plus-circle") me-2"></i>
                @(isEdit ? "Editar Loja" : "Nova Loja")
            </h1>
            <p class="page-subtitle">
                @(isEdit ? "Atualize os dados da unidade cadastrada" : "Preencha os dados para cadastrar uma nova unidade")
            </p>
        </div>

        <a asp-page="./Index" class="btn btn-soft-dark">
            <i class="bi bi-arrow-left me-2"></i>
            Voltar
        </a>
    </div>

    <div class="form-card">
        <div class="form-card-body">
            <form method="post" id="formLoja">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Loja.Id" />
                <input type="hidden" asp-for="Loja.DataCadastro" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <div class="field-block">
                            <label class="form-label">Nome da loja</label>
                            <input asp-for="Loja.Nome" class="form-control" placeholder="Ex.: Loja Centro" />
                            <small class="form-help">Nome comercial exibido no sistema.</small>
                            <span asp-validation-for="Loja.Nome" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6">
                        <div class="field-block">
                            <label class="form-label">Razão social</label>
                            <input asp-for="Loja.RazaoSocial" class="form-control" placeholder="Ex.: Empresa XPTO LTDA" />
                            <small class="form-help">Informe a razão social registrada no CNPJ.</small>
                            <span asp-validation-for="Loja.RazaoSocial" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="field-block">
                            <label class="form-label">CNPJ</label>
                            <input asp-for="Loja.Cnpj"
                                   id="Loja_Cnpj"
                                   class="form-control"
                                   placeholder="00.000.000/0000-00"
                                   inputmode="numeric"
                                   maxlength="18" />
                            <small class="form-help">Digite apenas números ou cole o CNPJ completo.</small>
                            <span asp-validation-for="Loja.Cnpj" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="field-block">
                            <label class="form-label">E-mail</label>
                            <input asp-for="Loja.Email" class="form-control" placeholder="email@loja.com.br" />
                            <small class="form-help">E-mail principal de contato da unidade.</small>
                            <span asp-validation-for="Loja.Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="field-block">
                            <label class="form-label">Telefone</label>
                            <input asp-for="Loja.Telefone"
                                   id="Loja_Telefone"
                                   class="form-control"
                                   placeholder="(00) 00000-0000"
                                   inputmode="numeric"
                                   maxlength="15" />
                            <small class="form-help">Telefone principal para atendimento e contato.</small>
                            <span asp-validation-for="Loja.Telefone" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <h6 class="section-title">Endereço</h6>

                <div class="row g-3">
                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="field-block">
                            <label class="form-label">CEP</label>
                            <input asp-for="Loja.Cep"
                                   id="Loja_Cep"
                                   class="form-control"
                                   placeholder="00000-000"
                                   inputmode="numeric"
                                   maxlength="9" />
                            <small class="form-help">Ao sair do campo, o endereço será buscado automaticamente.</small>
                            <span asp-validation-for="Loja.Cep" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12">
                        <div id="cepFeedback" class="alert-brand-info"></div>
                    </div>

                    <div class="col-12 col-lg-6">
                        <div class="field-block">
                            <label class="form-label">Endereço</label>
                            <input asp-for="Loja.Endereco" id="Loja_Endereco" class="form-control" placeholder="Rua, avenida, etc." />
                            <small class="form-help">Logradouro principal da unidade.</small>
                            <span asp-validation-for="Loja.Endereco" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-4 col-lg-2">
                        <div class="field-block">
                            <label asp-for="Loja.Numero" class="form-label">Número</label>
                            <input asp-for="Loja.Numero" class="form-control" placeholder="Ex.: 123" />
                            <small class="form-help">Número do imóvel.</small>
                            <span asp-validation-for="Loja.Numero" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-8 col-lg-4">
                        <div class="field-block">
                            <label class="form-label">Complemento</label>
                            <input asp-for="Loja.Complemento" class="form-control" placeholder="Sala, bloco, referência..." />
                            <small class="form-help">Opcional. Use para sala, bloco, conjunto ou referência.</small>
                            <span asp-validation-for="Loja.Complemento" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="field-block">
                            <label class="form-label">Bairro</label>
                            <input asp-for="Loja.Bairro" id="Loja_Bairro" class="form-control" placeholder="Bairro" />
                            <small class="form-help">Bairro da unidade.</small>
                            <span asp-validation-for="Loja.Bairro" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="field-block">
                            <label class="form-label">Cidade</label>
                            <input asp-for="Loja.Cidade" id="Loja_Cidade" class="form-control" placeholder="Cidade" />
                            <small class="form-help">Município onde a loja está localizada.</small>
                            <span asp-validation-for="Loja.Cidade" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="field-block">
                            <label class="form-label">UF</label>
                            <input asp-for="Loja.Uf"
                                   id="Loja_Uf"
                                   class="form-control text-uppercase"
                                   maxlength="2"
                                   placeholder="UF" />
                            <small class="form-help">Sigla do estado. Ex.: SP, RJ, MG.</small>
                            <span asp-validation-for="Loja.Uf" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="row g-3 align-items-center">
                    <div class="col-12 col-md-6">
                        <div class="switch-field">
                            <label class="switch-wrapper" for="Loja_Ativo">
                                <input asp-for="Loja.Ativo" class="switch-input" id="Loja_Ativo" type="checkbox" />
                                <span class="switch-slider"></span>
                                <span class="switch-text">
                                    <span class="switch-title">Loja ativa</span>
                                    <span class="switch-subtitle">Define se a unidade ficará disponível para uso no sistema.</span>
                                </span>
                            </label>

                            <span id="statusLojaAtiva" class="switch-status">Inativa</span>
                            <span asp-validation-for="Loja.Ativo" class="text-danger"></span>
                        </div>
                    </div>

                    @if (isEdit && Model.Loja.DataCadastro != default)
                    {
                        <div class="col-12 col-md-6 text-md-end">
                            <small class="text-muted">
                                Cadastro em: @Model.Loja.DataCadastro.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    }
                </div>

                <div class="form-actions">
                    <a asp-page="./Index" class="btn btn-soft-dark">
                        <i class="bi bi-x-circle me-2"></i>
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-brand">
                        <i class="bi bi-check-circle me-2"></i>
                        @(isEdit ? "Salvar alterações" : "Cadastrar loja")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        const form = document.getElementById('formLoja');
        const cnpjInput = document.getElementById('Loja_Cnpj');
        const telefoneInput = document.getElementById('Loja_Telefone');
        const cepInput = document.getElementById('Loja_Cep');
        const ufInput = document.getElementById('Loja_Uf');

        const enderecoInput = document.getElementById('Loja_Endereco');
        const bairroInput = document.getElementById('Loja_Bairro');
        const cidadeInput = document.getElementById('Loja_Cidade');
        const cepFeedback = document.getElementById('cepFeedback');

        const ativoInput = document.getElementById('Loja_Ativo');
        const statusLojaAtiva = document.getElementById('statusLojaAtiva');

        function onlyDigits(value) {
            return (value || '').replace(/\D/g, '');
        }

        function applyCnpjMask(value) {
            value = onlyDigits(value).slice(0, 14);

            if (value.length > 2) value = value.replace(/^(\d{2})(\d)/, '$1.$2');
            if (value.length > 6) value = value.replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3');
            if (value.length > 10) value = value.replace(/\.(\d{3})(\d)/, '.$1/$2');
            if (value.length > 15) value = value.replace(/(\d{4})(\d)/, '$1-$2');

            return value;
        }

        function applyTelefoneMask(value) {
            value = onlyDigits(value).slice(0, 11);

            if (value.length <= 10) {
                value = value.replace(/^(\d{0,2})(\d*)/, function (_, ddd, resto) {
                    return ddd ? '(' + ddd + (ddd.length === 2 ? ') ' : '') + resto : resto;
                });

                value = value.replace(/^(\(\d{2}\)\s)(\d{4})(\d+)/, '$1$2-$3');
            } else {
                value = value.replace(/^(\d{0,2})(\d*)/, function (_, ddd, resto) {
                    return ddd ? '(' + ddd + (ddd.length === 2 ? ') ' : '') + resto : resto;
                });

                value = value.replace(/^(\(\d{2}\)\s)(\d{5})(\d+)/, '$1$2-$3');
            }

            return value;
        }

        function applyCepMask(value) {
            value = onlyDigits(value).slice(0, 8);
            if (value.length > 5) {
                value = value.replace(/^(\d{5})(\d+)/, '$1-$2');
            }
            return value;
        }

        function applyUfMask(value) {
            return (value || '').replace(/[^a-zA-Z]/g, '').toUpperCase().slice(0, 2);
        }

        function setFeedback(message, isError) {
            if (!cepFeedback) return;
            cepFeedback.textContent = message || '';
            cepFeedback.style.display = message ? 'block' : 'none';
            cepFeedback.className = isError ? 'alert-brand-danger' : 'alert-brand-info';
        }

        function clearEnderecoFields() {
            if (enderecoInput) enderecoInput.value = '';
            if (bairroInput) bairroInput.value = '';
            if (cidadeInput) cidadeInput.value = '';
            if (ufInput) ufInput.value = '';
        }

        function updateAtivoStatus() {
            if (!ativoInput || !statusLojaAtiva) return;

            if (ativoInput.checked) {
                statusLojaAtiva.textContent = 'Ativa';
                statusLojaAtiva.classList.add('active');
            } else {
                statusLojaAtiva.textContent = 'Inativa';
                statusLojaAtiva.classList.remove('active');
            }
        }

        async function buscarCep() {
            if (!cepInput) return;

            const cep = onlyDigits(cepInput.value);
            setFeedback('', false);

            if (!cep) return;

            if (cep.length !== 8) {
                setFeedback('Informe um CEP válido com 8 dígitos.', true);
                return;
            }

            try {
                setFeedback('Buscando endereço pelo CEP...', false);

                const response = await fetch('https://viacep.com.br/ws/' + cep + '/json/');
                if (!response.ok) {
                    throw new Error('Falha ao consultar CEP');
                }

                const data = await response.json();

                if (data.erro) {
                    clearEnderecoFields();
                    setFeedback('CEP não encontrado.', true);
                    return;
                }

                if (enderecoInput) enderecoInput.value = data.logradouro || '';
                if (bairroInput) bairroInput.value = data.bairro || '';
                if (cidadeInput) cidadeInput.value = data.localidade || '';
                if (ufInput) ufInput.value = data.uf || '';

                setFeedback('Endereço preenchido automaticamente pelo CEP.', false);
            } catch {
                setFeedback('Não foi possível consultar o CEP no momento.', true);
            }
        }

        if (cnpjInput) {
            cnpjInput.addEventListener('input', function () {
                this.value = applyCnpjMask(this.value);
            });
            cnpjInput.value = applyCnpjMask(cnpjInput.value);
        }

        if (telefoneInput) {
            telefoneInput.addEventListener('input', function () {
                this.value = applyTelefoneMask(this.value);
            });
            telefoneInput.value = applyTelefoneMask(telefoneInput.value);
        }

        if (cepInput) {
            cepInput.addEventListener('input', function () {
                this.value = applyCepMask(this.value);
            });
            cepInput.addEventListener('blur', buscarCep);
            cepInput.value = applyCepMask(cepInput.value);
        }

        if (ufInput) {
            ufInput.addEventListener('input', function () {
                this.value = applyUfMask(this.value);
            });
            ufInput.value = applyUfMask(ufInput.value);
        }

        if (ativoInput) {
            ativoInput.addEventListener('change', updateAtivoStatus);
            updateAtivoStatus();
        }

        if (form) {
            form.addEventListener('submit', function () {
                if (cnpjInput) cnpjInput.value = onlyDigits(cnpjInput.value);
                if (telefoneInput) telefoneInput.value = onlyDigits(telefoneInput.value);
                if (cepInput) cepInput.value = onlyDigits(cepInput.value);
                if (ufInput) ufInput.value = applyUfMask(ufInput.value);
            });
        }
    })();
</script>